# API Server URL
# For development: leave blank to use relative URLs (server runs on same port as client)
# For production: set to your Render server URL (e.g., https://addcontact-server.onrender.com)
VITE_API_URL=

# Zapier integration page
VITE_ZAPIER_INVITE_URL=https://zapier.com/developer/public-invite/240507/da63c72aee602b7838b5e5b8d6d72396/
VITE_ZAPIER_APP_CLI_NAME=

# Server-side environment variables (not used by client)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
DATABASE_URL=
JWT_SECRET=
INTERNAL_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Dynamic Image Personalizer (optional)
# The custom field key used for storing dynamic image URLs in GHL
# This field will be auto-discovered by name in each subaccount
# No configuration needed - just ensure the field exists in GHL Settings > Custom Fields
# Field name: "dynamic_image_url" (type: Text)
